---
import { navItems, siteConfig } from "../../data/site";
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/75 backdrop-blur-xl">
  <div class="section-container flex min-h-18 items-center justify-between gap-6">
    <a href="/" class="flex items-center gap-3 font-black tracking-tight">
      <span class="grid size-10 place-items-center rounded-2xl bg-cyan-300 text-slate-950">
        AF
      </span>
      <span>{siteConfig.name}</span>
    </a>

    <nav class="hidden items-center gap-1 text-sm text-slate-300 md:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="rounded-full px-4 py-2 transition hover:bg-white/10 hover:text-white"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href={siteConfig.cvUrl}
      class="hidden rounded-full border border-white/15 px-4 py-2 text-sm font-bold text-white transition hover:bg-white/10 md:inline-flex"
    >
      Descargar CV
    </a>
  </div>
</header>