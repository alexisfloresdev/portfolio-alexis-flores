---
import { siteConfig } from "../../data/site";
---

<section class="section-container flex min-h-[calc(100vh-4.5rem)] items-center py-20">
  <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
    <div>
      <p class="mb-5 inline-flex rounded-full border border-cyan-300/30 bg-cyan-300/10 px-4 py-2 text-sm font-bold text-cyan-200">
        Data · Software · Machine Learning
      </p>

      <h1 class="max-w-4xl text-5xl font-black leading-[0.95] tracking-[-0.06em] text-white md:text-7xl">
        Informático orientado a datos, software y soluciones escalables.
      </h1>

      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
        Soy {siteConfig.fullName}, informático de 22 años interesado en Big Data,
        Ciencia de Datos, Machine Learning, cloud y desarrollo de sistemas mantenibles.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="#proyectos"
          class="rounded-full bg-cyan-300 px-5 py-3 font-black text-slate-950 transition hover:bg-cyan-200"
        >
          Ver proyectos
        </a>

        <a
          href={`mailto:${siteConfig.email}`}
          class="rounded-full border border-white/15 px-5 py-3 font-black text-white transition hover:bg-white/10"
        >
          Contactar
        </a>
      </div>
    </div>

    <aside class="glass-card rounded-[2rem] p-6">
      <div class="mb-5 flex gap-2">
        <span class="size-3 rounded-full bg-red-400"></span>
        <span class="size-3 rounded-full bg-yellow-300"></span>
        <span class="size-3 rounded-full bg-cyan-300"></span>
      </div>

      <pre class="overflow-x-auto text-sm leading-7 text-slate-300"><code><span class="text-cyan-300">alexis@portfolio</span>:~$ init --profile

role: "Data & Software"
focus: ["Big Data", "ML", "Cloud"]
stack: ["Python", "Java", "SQL", "Astro"]
status: "building professional portfolio"</code></pre>
    </aside>
  </div>
</section>