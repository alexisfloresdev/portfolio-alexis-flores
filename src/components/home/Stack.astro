---
import { skills } from "../../data/site";
---

<section id="stack" class="section-container py-24">
  <div class="mb-10 max-w-3xl">
    <p class="mb-3 text-sm font-black uppercase tracking-[0.25em] text-cyan-300">
      Stack
    </p>
    <h2 class="text-4xl font-black tracking-[-0.05em] md:text-5xl">
      Tecnologías que conectan desarrollo, datos y cloud.
    </h2>
  </div>

  <div class="glass-card rounded-[2rem] p-6">
    <div class="flex flex-wrap gap-3">
      {skills.map((skill) => (
        <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-bold text-slate-200">
          {skill}
        </span>
      ))}
    </div>
  </div>
</section>