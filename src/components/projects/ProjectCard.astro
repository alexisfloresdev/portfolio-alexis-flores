---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const href = `/proyectos/${project.id}/`;
---

<article class="glass-card group flex h-full flex-col overflow-hidden rounded-3xl transition hover:-translate-y-1 hover:bg-white/10">
  <a href={href} class="flex h-full flex-col p-6">
    <div class="mb-5 flex items-center justify-between gap-4">
      <span class="rounded-full border border-cyan-300/20 bg-cyan-300/10 px-3 py-1 text-xs font-black uppercase tracking-[0.18em] text-cyan-200">
        {project.data.category}
      </span>

      <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-bold text-slate-300">
        {project.data.status}
      </span>
    </div>

    <h3 class="text-2xl font-black tracking-[-0.04em] text-white">
      {project.data.title}
    </h3>

    <p class="mt-3 flex-1 text-slate-300">
      {project.data.summary}
    </p>

    <div class="mt-6 flex flex-wrap gap-2">
      {project.data.tags.map((tag) => (
        <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-bold text-slate-300">
          {tag}
        </span>
      ))}
    </div>

    <div class="mt-6 font-black text-cyan-300 transition group-hover:text-cyan-200">
      Ver caso de estudio →
    </div>
  </a>
</article>